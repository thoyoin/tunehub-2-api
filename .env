APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share

DEFAULT_URI=http://localhost/api

DATABASE_URL="mysql://tunehub:secret@mysql:3306/tunehub?serverVersion=8.4&charset=utf8mb4"

MYSQL_DATABASE=tunehub
MYSQL_USER=tunehub
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=root

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=tunehub
AWS_ENDPOINT=http://minio:9000
AWS_PUBLIC_ENDPOINT=http://127.0.0.1:9000


DEFAULT_PROFILE_PICTURE=http://localhost:9000/tunehub/defaults/profile_cover.jpg
DEFAULT_COVER=http://localhost:9000/tunehub/defaults/default_cover.jpg

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
